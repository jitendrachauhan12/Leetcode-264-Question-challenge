class Solution {
    public boolean isPalindrome(int x) {
        if (x < 0) {
            return false;
        }

        int n = x;
        int revval = 0;

        while (n > 0) {
            int d = n % 10;
            revval = revval * 10 + d;
            n = n / 10;
        }

        if (revval == x) {
            return true;
        } else {
            return false;
        }
    }
}